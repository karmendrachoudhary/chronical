{
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "name": "chronicle-capture",
            "command": "node \"$(git rev-parse --show-toplevel)/bin/chronicle.js\" capture --hook-input - --source-tool gemini --render --hook-mode",
            "timeout": 60000,
            "description": "Capture a Chronicle devlog event when Gemini CLI ends a session."
          }
        ]
      }
    ]
  }
}
