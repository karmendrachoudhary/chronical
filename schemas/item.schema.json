{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chronicle.dev/schemas/item.schema.json",
  "title": "Chronicle Unified Store",
  "type": "object",
  "required": ["schema_version", "items"],
  "properties": {
    "schema_version": { "type": "integer", "const": 2 },
    "generated_by": { "type": "string" },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/item" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "links": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "item": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "title",
        "summary",
        "raw_summary",
        "public_summary",
        "date",
        "tech",
        "tags",
        "files_touched",
        "visibility",
        "confidence",
        "status",
        "files",
        "links",
        "data",
        "safety_flags",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^(evt|feat|file|dec|plan|rel|act)_[a-z0-9_-]{4,}$" },
        "kind": { "type": "string", "enum": ["event", "feature", "file", "decision", "roadmap", "release", "action_intent"] },
        "type": { "type": "string", "enum": ["feature_added", "bugfix", "refactor", "dependency_changed", "version_bump", "decision", "note"] },
        "title": { "type": "string", "minLength": 1, "maxLength": 160 },
        "summary": { "type": "string" },
        "raw_summary": { "type": "string" },
        "public_summary": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "session_id": { "type": "string" },
        "source_tool": { "type": "string", "enum": ["claude-code", "codex", "gemini"] },
        "tech": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "files_touched": { "type": "integer", "minimum": 0 },
        "visibility": { "type": "string", "enum": ["private", "team", "public"] },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
        "status": { "type": "string", "enum": ["completed", "blocked", "in_progress", "planned", "idea", "unknown"] },
        "source_ref": { "type": "object" },
        "files": { "type": "array", "items": { "type": "string" } },
        "links": { "$ref": "#/$defs/links" },
        "data": { "type": "object" },
        "safety_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(raw_summary|public_summary|title|summary):[a-z0-9_]+$"
          }
        },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "event" } }, "required": ["kind"] },
          "then": { "required": ["type", "session_id", "source_tool"] }
        },
        {
          "if": { "properties": { "visibility": { "const": "public" } }, "required": ["visibility"] },
          "then": {
            "properties": {
              "public_summary": { "minLength": 1 },
              "safety_flags": { "maxItems": 0 }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  }
}
